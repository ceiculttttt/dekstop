<UserControl x:Class="AnsemBullOverlay.Controls.ChatBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Grid>
        <!-- Neon bubble body -->
        <Border x:Name="Body"
                Background="#F00A0F0B"
                BorderBrush="#FF39FF14"
                BorderThickness="1.5"
                CornerRadius="14"
                Padding="14,10"
                MaxWidth="280">
            <Border.Effect>
                <DropShadowEffect Color="#39FF14" BlurRadius="26" ShadowDepth="0" Opacity="0.85"/>
            </Border.Effect>
            <TextBlock x:Name="Text"
                       Foreground="#FFE8FFEA"
                       FontFamily="Consolas"
                       FontWeight="SemiBold"
                       FontSize="15"
                       LineHeight="20"
                       TextWrapping="Wrap"
                       TextAlignment="Left"/>
        </Border>
        <!-- Speech tail (points down toward the bull) -->
        <Path Fill="#F00A0F0B" Stroke="#FF39FF14" StrokeThickness="1.5"
              HorizontalAlignment="Left" VerticalAlignment="Bottom"
              Margin="26,0,0,-9"
              Data="M 0,0 L 14,0 L 7,10 Z">
            <Path.Effect>
                <DropShadowEffect Color="#39FF14" BlurRadius="14" ShadowDepth="0" Opacity="0.8"/>
            </Path.Effect>
        </Path>
    </Grid>
</UserControl>
