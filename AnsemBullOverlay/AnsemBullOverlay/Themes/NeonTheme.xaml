<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Ansem-inspired palette: obsidian black, matrix neon green, ice-white horns, chart red accents -->
    <Color x:Key="NeonGreenColor">#FF39FF14</Color>
    <Color x:Key="NeonGreenSoftColor">#FF6CFF5A</Color>
    <Color x:Key="ObsidianColor">#FF050607</Color>
    <Color x:Key="CarbonColor">#FF121417</Color>
    <Color x:Key="IceColor">#FFE8F1EA</Color>
    <Color x:Key="ChartRedColor">#FFFF3B57</Color>
    <Color x:Key="ChartGreenColor">#FF00E676</Color>
    <Color x:Key="DiamondCoreColor">#FFB6FFF7</Color>
    <Color x:Key="DiamondEdgeColor">#FF39FF14</Color>

    <SolidColorBrush x:Key="NeonGreenBrush" Color="{StaticResource NeonGreenColor}"/>
    <SolidColorBrush x:Key="NeonGreenSoftBrush" Color="{StaticResource NeonGreenSoftColor}"/>
    <SolidColorBrush x:Key="ObsidianBrush" Color="{StaticResource ObsidianColor}"/>
    <SolidColorBrush x:Key="CarbonBrush" Color="{StaticResource CarbonColor}"/>
    <SolidColorBrush x:Key="IceBrush" Color="{StaticResource IceColor}"/>
    <SolidColorBrush x:Key="ChartRedBrush" Color="{StaticResource ChartRedColor}"/>
    <SolidColorBrush x:Key="ChartGreenBrush" Color="{StaticResource ChartGreenColor}"/>

    <LinearGradientBrush x:Key="DiamondBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFB6FFF7" Offset="0"/>
        <GradientStop Color="#FF39FF14" Offset="0.55"/>
        <GradientStop Color="#FF0AAA30" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BullBodyBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF141618" Offset="0"/>
        <GradientStop Color="#FF050607" Offset="1"/>
    </LinearGradientBrush>

    <!-- Reusable neon glow effect for the bull silhouette and candles -->
    <DropShadowEffect x:Key="NeonGlow"
                      Color="{StaticResource NeonGreenColor}"
                      BlurRadius="28"
                      ShadowDepth="0"
                      Opacity="0.85"/>

    <DropShadowEffect x:Key="SoftNeonGlow"
                      Color="{StaticResource NeonGreenColor}"
                      BlurRadius="14"
                      ShadowDepth="0"
                      Opacity="0.65"/>

    <!-- Config window styling -->
    <Style x:Key="NeonButton" TargetType="Button">
        <Setter Property="Background" Value="#FF0B0D0E"/>
        <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource NeonGreenBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FF122015"/>
                            <Setter TargetName="Bd" Property="Effect" Value="{StaticResource SoftNeonGlow}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FF1E3520"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeonCheck" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource IceBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="Margin" Value="0,6"/>
    </Style>

    <Style x:Key="NeonLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,10,0,4"/>
    </Style>

    <Style x:Key="NeonSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
        <Setter Property="Background" Value="#FF1A1E1F"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

</ResourceDictionary>
