<Window x:Class="AnsemBullOverlay.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ANSEM BULL // Control Deck"
        Width="520" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#FF07090A"
        Foreground="#FFE8F1EA"
        FontFamily="Consolas"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock" BasedOn="{StaticResource NeonLabel}"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource NeonGreenBrush}" BorderThickness="1" Padding="18">
        <Border.Effect>
            <DropShadowEffect Color="#39FF14" BlurRadius="24" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="◆  ANSEM BULL — CONTROL DECK  ◆"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource NeonGreenBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18"/>

                <TextBlock Text="EFFECTS"/>
                <CheckBox Style="{StaticResource NeonCheck}" Content="Bull mascot"           IsChecked="{Binding EnableBull}"/>
                <CheckBox Style="{StaticResource NeonCheck}" Content="Floating candlesticks" IsChecked="{Binding EnableCandles}"/>
                <CheckBox Style="{StaticResource NeonCheck}" Content="Bull-head cursor trail" IsChecked="{Binding EnableMouseTrail}"/>
                <CheckBox Style="{StaticResource NeonCheck}" Content="Click explosion"       IsChecked="{Binding EnableClickExplosion}"/>

                <TextBlock Text="BULL SCALE"/>
                <Slider Style="{StaticResource NeonSlider}" Minimum="0.5" Maximum="2" TickFrequency="0.25"
                        Value="{Binding BullScale, Mode=TwoWay}"/>

                <TextBlock Text="BULL SPEED"/>
                <Slider Style="{StaticResource NeonSlider}" Minimum="0.25" Maximum="3" TickFrequency="0.25"
                        Value="{Binding BullSpeed, Mode=TwoWay}"/>

                <TextBlock Text="GLOW INTENSITY"/>
                <Slider Style="{StaticResource NeonSlider}" Minimum="0" Maximum="2" TickFrequency="0.1"
                        Value="{Binding GlowIntensity, Mode=TwoWay}"/>

                <TextBlock Text="PARTICLE DENSITY"/>
                <Slider Style="{StaticResource NeonSlider}" Minimum="0.25" Maximum="2" TickFrequency="0.25"
                        Value="{Binding ParticleDensity, Mode=TwoWay}"/>

                <TextBlock Text="SYSTEM"/>
                <CheckBox Style="{StaticResource NeonCheck}" Content="Start with Windows" IsChecked="{Binding AutoStart}"/>

                <TextBlock Text="HOTKEYS"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Bull Charge    :  Ctrl + Shift + B" Foreground="#FFCFEED0" Margin="0,2"/>
                    <TextBlock Text="Rocket Boost   :  Ctrl + Shift + R" Foreground="#FFCFEED0" Margin="0,2"/>
                    <TextBlock Text="Say Something  :  Ctrl + Shift + T" Foreground="#FFCFEED0" Margin="0,2"/>
                    <TextBlock Text="Toggle Overlay :  Ctrl + Shift + H" Foreground="#FFCFEED0" Margin="0,2"/>
                </StackPanel>

                <TextBlock Text="TIP" Margin="0,16,0,4"/>
                <TextBlock Text="Click the bull anywhere on your desktop to make it talk!"
                           Foreground="#FFCFEED0"/>

                <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                    <Button Style="{StaticResource NeonButton}" Content="Charge"
                            Command="{Binding TestChargeCommand}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource NeonButton}" Content="Rocket"
                            Command="{Binding TestRocketCommand}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource NeonButton}" Content="Talk"
                            Command="{Binding TestTalkCommand}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource NeonButton}" Content="Reset"
                            Command="{Binding ResetCommand}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource NeonButton}" Content="Save"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>

                <TextBlock Text="Right-click the tray icon for quick commands."
                           FontStyle="Italic"
                           Foreground="#FF89A78E"
                           Margin="0,18,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
